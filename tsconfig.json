{
    "compilerOptions": {
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "jsx": "react",
        "rootDir": "./src",
        "baseUrl": "./src",
        "outDir": "./dist",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "ignoreDeprecations": "5.0",
        "paths": {
            "@/*": ["*"],
            "stremio/*": ["*"],
        },
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": false,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
    },
    "include": [
        "src/",
    ]
}
