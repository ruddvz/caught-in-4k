# Caught in 4K Environment Configuration

# === AI API Configuration ===
# Pollinations.AI is the PRIMARY AI provider (free, no signup, no API key required)
# Canon Takes and Satisfaction Meter one-liners are generated via Pollinations.AI
# No configuration needed — it works out of the box!

# Canon Takes API Proxy URL (OPTIONAL — Gemini proxy fallback)
# Only needed if Pollinations.AI is unavailable
# This is the backend proxy that calls Gemini API
# Set this to the URL where you deploy the api-proxy-template.js
# Examples:
#   - Local development: http://localhost:3001/api/canon-take
#   - Vercel: https://your-project.vercel.app/api/canon-take
#   - Netlify: https://your-project.netlify.app/.netlify/functions/canon-take
REACT_APP_CANON_PROXY_URL=

# General API base for billing/admin endpoints when the frontend is deployed statically
# Example: https://api.c4k.live
REACT_APP_API_BASE_URL=

# === Supabase Configuration (for C4K auth & subscriptions) ===
# Get these from https://app.supabase.com → Project Settings → API
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# === Stripe Configuration (for subscriptions) ===
# Get the publishable key from https://dashboard.stripe.com/apikeys
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# === Backend-only keys (used in api-proxy.js, NOT in frontend) ===
# Public app URL for Stripe success/cancel redirects and backend CORS allowlisting
# This can include a subpath if the frontend is not served from /.
# Examples: https://c4k.live or https://c4k.live/app
APP_BASE_URL=
# Optional comma-separated extra allowed frontend origins
# Example: https://preview.c4k.live,https://staging.c4k.live
ALLOWED_APP_ORIGINS=
# Stripe secret key — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Stripe webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# Supabase service role key (admin access) — Project Settings → API → service_role
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NOTE: The Gemini API key is stored on the backend only (in api-proxy.js / api-proxy-template.js)
# Do NOT expose any API keys in the frontend code

# ── Token Optimization (Headroom + RTK + MemStack) ──
# Set ANTHROPIC_BASE_URL to route Claude Code through Headroom proxy for ~34% token savings
# Only set this when Headroom is running: `headroom proxy --port 8787`
# Start automatically with: scripts/setup/start-claude.bat (Windows) or start-claude.sh (Unix)
ANTHROPIC_BASE_URL=http://127.0.0.1:8787
# RTK telemetry opt-out (already set in .claude/settings.json; include here for shell sessions)
RTK_TELEMETRY_DISABLED=1

# ── Claude Organize (AI-powered file organization via Claude Code hooks) ──
# Set BYPASS=true to temporarily disable auto-organization
CLAUDE_ORGANIZE_BYPASS=false
CLAUDE_ORGANIZE_DEBUG=false
# Comma-separated glob patterns of files that should NEVER be moved
CLAUDE_ORGANIZE_SKIP_PATTERNS=*.config.js,*.config.mjs,webpack.config.js,api-proxy.js,api-proxy-template.js,http_server.js,generate-icons.js,setup.bat,setup.sh,DESIGN.md,CANON_TAKES_SETUP.md,QUICK_START.md,READY_CHECKLIST.md,organizing.md,CHANGELOG.md,CODE_OF_CONDUCT.md,LICENSE,LICENSE.md,Dockerfile,README.md
# JavaScript file organization (EXPERIMENTAL - leave false)
CLAUDE_ORGANIZE_JS=false
CLAUDE_ORGANIZE_JS_MODE=safe
